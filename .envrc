#!/usr/bin/env bash
watch_file devshell.nix flake.nix flake.lock .flake-archive.json
local sys attr profile
sys=$(nix eval --raw --impure --expr builtins.currentSystem)
attr="devShells.$sys.default"
profile="$(direnv_layout_dir)/profile"
mkdir -p "$(direnv_layout_dir)"

if has iets && [[ -f .flake-archive.json ]]; then
  out=$(iets build --allowed-path / -E "(import ./default.nix).$attr" 2>/dev/null) \
    && ln -sfn "$out" "$profile"
fi
[[ -d "$profile/bin" ]] || nix build --out-link "$profile" --accept-flake-config ".#$attr"

PATH_add "$profile/bin"
export PRJ_ROOT=$PWD
export KIN_IDENTITY="${KIN_IDENTITY:-$PRJ_ROOT/keys/users/$(whoami).key}"
source_env_if_exists .envrc.local
