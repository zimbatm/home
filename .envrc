#!/usr/bin/env bash
watch_file devshell.nix flake.nix flake.lock
system=$(nix eval --raw --impure --expr builtins.currentSystem)
attr="devShells.$system.default"

# Try iets for the eval (via flake-shim) — falls back to cppnix until B3 (fetchGit) lands.
drv=""
if command -v iets >/dev/null; then
  drv=$(iets eval --allowed-path / default.nix -A "$attr.drvPath" 2>/dev/null) || drv=""
fi
if [[ -n "$drv" ]]; then
  nix build --out-link .direnv/profile --accept-flake-config "${drv}^out"
else
  nix build --out-link .direnv/profile --accept-flake-config ".#$attr"
fi

PATH_add .direnv/profile/bin
export PRJ_ROOT=$PWD
export KIN_IDENTITY="${KIN_IDENTITY:-$PRJ_ROOT/keys/users/$(whoami).key}"
source_env_if_exists .envrc.local
