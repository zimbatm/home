#!/usr/bin/env bash
watch_file devshell.nix flake.nix flake.lock
local attr profile
attr="devShells.$(nix eval --raw --impure --expr builtins.currentSystem).default"
profile="$(direnv_layout_dir)/profile"
mkdir -p "$(direnv_layout_dir)"

if has iets \
   && out=$(iets build --impure --allowed-path / -E "(import ./default.nix).$attr" 2>/dev/null); then
  nix-store --add-root "$profile" --indirect -r "$out" >/dev/null
else
  nix build --out-link "$profile" ".#$attr"
fi
[[ -d "$profile/bin" ]] || fail "oops, $profile is empty"

PATH_add "$profile/bin"
export PRJ_ROOT=$PWD
export KIN_IDENTITY="${KIN_IDENTITY:-$PRJ_ROOT/keys/users/$(whoami).key}"
source_env_if_exists .envrc.local
