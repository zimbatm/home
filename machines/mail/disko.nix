{
  # UEFI GPT layout: 512 MiB ESP at /boot, rest ext4 root. systemd-boot
  # installs to the ESP. Hetzner Cloud Volumes are external and intentionally
  # NOT in disko — disko would otherwise wipe them.
  disko.devices.disk.main = {
    type = "disk";
    device = "/dev/sda";
    content = {
      type = "gpt";
      partitions = {
        esp = {
          size = "512M";
          type = "EF00";
          content = {
            type = "filesystem";
            format = "vfat";
            mountpoint = "/boot";
            mountOptions = [ "umask=0077" ];
          };
        };
        root = {
          size = "100%";
          content = {
            type = "filesystem";
            format = "ext4";
            mountpoint = "/";
          };
        };
      };
    };
  };
}
