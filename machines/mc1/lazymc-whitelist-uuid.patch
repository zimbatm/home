+/// Decode the player UUID a 1.20.2+ client appends after the name in Login
+/// Start, formatted lowercase-hyphenated to match `whitelist.json`.
+///
+/// `rest` is the Login Start packet body positioned right after the username.
+/// Returns `None` for older clients that don't send a UUID here.
+fn decode_login_uuid(rest: &[u8]) -> Option<String> {
+    let bytes = rest.get(..16)?;
+    let hex: String = bytes.iter().map(|b| format!("{b:02x}")).collect();
+    Some(format!(
+        "{}-{}-{}-{}-{}",
+        &hex[0..8],
+        &hex[8..12],
+        &hex[12..16],
+        &hex[16..20],
+        &hex[20..32],
+    ))
+}
